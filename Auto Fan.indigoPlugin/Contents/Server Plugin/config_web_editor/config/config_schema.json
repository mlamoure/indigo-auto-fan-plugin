{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Auto Fan Configuration Schema",
  "type": "object",
  "properties": {
    "plugin_config": {
      "type": "object",
      "properties": {
        "default_lock_duration": {
          "type": "integer",
          "x-sync_to_indigo": true,
          "title": "Default Lock Duration (minutes)",
          "tooltip": "Duration in minutes that a zone stays locked after a manual fan change.",
          "default": 60
        },
        "default_lock_extension_duration": {
          "type": "integer",
          "x-sync_to_indigo": true,
          "title": "Default Lock Extension Duration (minutes)",
          "tooltip": "Duration in minutes to extend the lock when presence is detected.",
          "default": 30
        },
        "weather_dev_id": {
          "type": "integer",
          "x-sync_to_indigo": true,
          "x-drop-down": true,
          "title": "Weather Device (Outdoor Temp)",
          "tooltip": "Device providing outdoor temperature (feelslike, temp, or temperature state)."
        }
      }
    },
    "zones": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "x-sync_to_indigo": true,
            "title": "Zone Name"
          },
          "enabled": {
            "type": "boolean",
            "x-sync_to_indigo": true,
            "title": "Zone Enabled",
            "default": true
          },
          "zone_index": {
            "type": "integer",
            "title": "Zone Index"
          },
          "indigo_dev_id": {
            "type": "integer",
            "title": "Indigo Device ID"
          },
          "fan_dev_id": {
            "type": "integer",
            "x-sync_to_indigo": true,
            "x-drop-down": true,
            "x-include-device-classes": "indigo.SpeedControlDevice,indigo.DimmerDevice,indigo.RelayDevice",
            "title": "Fan Device"
          },
          "temp_sensor_dev_ids": {
            "type": "array",
            "x-sync_to_indigo": true,
            "x-drop-down": true,
            "x-include-device-classes": "indigo.SensorDevice",
            "items": {"type": "integer"},
            "title": "Temperature Sensor(s)",
            "tooltip": "One or more temp sensors. If multiple, average is used.",
            "default": []
          },
          "presence_dev_ids": {
            "type": "array",
            "x-sync_to_indigo": true,
            "x-drop-down": true,
            "x-include-device-classes": "indigo.SensorDevice",
            "items": {"type": "integer"},
            "title": "Presence Sensors",
            "default": []
          },
          "thermostat_dev_id": {
            "type": "integer",
            "x-sync_to_indigo": true,
            "x-drop-down": true,
            "x-include-device-classes": "indigo.ThermostatDevice",
            "title": "Thermostat"
          },
          "humidity_dev_ids": {
            "type": "array",
            "x-sync_to_indigo": true,
            "x-drop-down": true,
            "x-include-device-classes": "indigo.SensorDevice",
            "items": {"type": "integer"},
            "title": "Humidity Sensor(s)",
            "tooltip": "One or more humidity sensors. If multiple, average is used.",
            "default": []
          },
          "ideal_temp_value": {
            "type": "number",
            "x-sync_to_indigo": true,
            "title": "Ideal Temperature",
            "default": 72
          },
          "ideal_temp_source": {
            "type": "string",
            "title": "Ideal Temperature Source",
            "enum": ["static", "variable", "thermostat"],
            "default": "static",
            "tooltip": "How to determine the ideal temperature. 'thermostat' uses the heat setpoint, cool setpoint, or average of both when in auto mode."
          },
          "ideal_temp_var_id": {
            "type": "integer",
            "x-drop-down": true,
            "title": "Ideal Temperature Variable"
          },
          "seasonal_curves": {
            "type": "object",
            "title": "Seasonal Fan Curves",
            "properties": {
              "spring": { "$ref": "#/definitions/fan_curve" },
              "summer": { "$ref": "#/definitions/fan_curve" },
              "fall":   { "$ref": "#/definitions/fan_curve" },
              "winter": { "$ref": "#/definitions/fan_curve" }
            }
          },
          "modifiers": {
            "type": "object",
            "title": "Speed Modifiers",
            "properties": {
              "hvac_cooling_active": {
                "type": "object",
                "title": "HVAC Cooling Modifier",
                "properties": {
                  "enabled": {"type": "boolean", "default": true},
                  "speed_adjust_pct": {"type": "number", "default": 15, "title": "Speed Boost When Cooling (%)"}
                }
              },
              "hvac_heating_active": {
                "type": "object",
                "title": "HVAC Heating Modifier",
                "properties": {
                  "enabled": {"type": "boolean", "default": true},
                  "speed_adjust_pct": {"type": "number", "default": -20, "title": "Speed Reduction When Heating (%)"},
                  "clamp_min_pct": {"type": "number", "default": 0, "title": "Minimum Speed When Heating (%)"}
                }
              },
              "nighttime": {
                "type": "object",
                "title": "Nighttime Modifier",
                "properties": {
                  "enabled": {"type": "boolean", "default": true},
                  "clamp_min_pct": {"type": "number", "default": 0, "title": "Min Speed at Night (%)"},
                  "clamp_max_pct": {"type": "number", "default": 50, "title": "Max Speed at Night (%)"},
                  "night_start_hour": {"type": "integer", "default": 22, "minimum": 0, "maximum": 23, "title": "Night Start Hour"},
                  "night_end_hour": {"type": "integer", "default": 8, "minimum": 0, "maximum": 23, "title": "Night End Hour"}
                }
              },
              "humidity": {
                "type": "object",
                "title": "Humidity Modifier",
                "properties": {
                  "enabled": {"type": "boolean", "default": false},
                  "threshold": {"type": "number", "default": 60, "title": "Humidity Threshold (%)"},
                  "speed_adjust_per_unit_pct": {"type": "number", "default": 0.5, "title": "Speed Boost Per % Over Threshold"},
                  "max_adjust_pct": {"type": "number", "default": 15, "title": "Max Humidity Boost (%)"}
                }
              },
              "no_presence": {
                "type": "object",
                "title": "No Presence Modifier",
                "properties": {
                  "enabled": {"type": "boolean", "default": true},
                  "clamp_max_pct": {"type": "number", "default": 0, "title": "Max Speed When No Presence (%)"}
                }
              }
            }
          },
          "lock_duration": {
            "type": "integer",
            "x-sync_to_indigo": true,
            "title": "Lock Duration (minutes)",
            "tooltip": "Override default lock duration for this zone. -1 uses plugin default.",
            "default": -1
          },
          "lock_extension_duration": {
            "type": "integer",
            "x-sync_to_indigo": true,
            "title": "Lock Extension Duration (minutes)",
            "default": -1
          }
        },
        "required": ["name"]
      }
    }
  },
  "required": ["plugin_config", "zones"],
  "definitions": {
    "fan_curve": {
      "type": "object",
      "properties": {
        "temperature_range": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "default": 3,
          "title": "Temperature Range (degrees)"
        },
        "num_points": {
          "type": "integer",
          "minimum": 3,
          "maximum": 11,
          "default": 7,
          "title": "Number of Control Points"
        },
        "points": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "offset": {"type": "number", "title": "Temp Offset"},
              "speed": {"type": "number", "minimum": 0, "maximum": 100, "title": "Fan Speed %"}
            },
            "required": ["offset", "speed"]
          },
          "default": [
            {"offset": -3.0, "speed": 0},
            {"offset": -2.0, "speed": 10},
            {"offset": -1.0, "speed": 20},
            {"offset": 0.0, "speed": 30},
            {"offset": 1.0, "speed": 55},
            {"offset": 2.0, "speed": 80},
            {"offset": 3.0, "speed": 100}
          ]
        }
      }
    }
  }
}
